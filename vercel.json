{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/meta-webhook",
      "dest": "/api/meta-webhook.js"
    },
    {
      "src": "/api/meta-capi",
      "dest": "/api/meta-capi.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
